{
  "name": "edge-track",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "vite build",
    "dev": "npm run build && wrangler d1 migrations apply edge-track --local && wrangler dev --local",
    "dev:ui": "vite",
    "check": "tsc --noEmit && vite build",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply edge-track --local",
    "db:migrate": "wrangler d1 migrations apply edge-track --remote"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.8",
    "typescript": "^5.8.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.1.5",
    "wrangler": "^4.112.0"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "echarts": "^6.1.0",
    "element-plus": "^2.14.3",
    "ua-parser-js": "^2.0.10",
    "vue": "^3.5.40"
  }
}
