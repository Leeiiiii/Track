    "db:migrate": "wrangler d1 migrations apply edge-track --remote"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "wrangler": "^4.112.0"
  },
  "dependencies": {
    "ua-parser-js": "^2.0.10"
  }
}
