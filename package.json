{
  "name": "edge-track",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler d1 migrations apply edge-track --local && wrangler dev --local",
    "check": "tsc --noEmit",
    "deploy": "wrangler deploy",
